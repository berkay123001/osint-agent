# ─── Required ──────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Self-Hosted Search & Scraping (Docker) ────────────────
# Start with: docker compose up -d
SEARXNG_URL=http://localhost:8888
FIRECRAWL_URL=http://localhost:3002/v1/scrape

# ─── Search Engines (chain: SearXNG → Brave → Google CSE → Tavily) ──────────
BRAVE_SEARCH_API_KEY=BSA...
# Google Custom Search — https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
TAVILY_API_KEY=tvly-...
# Firecrawl Cloud fallback — only when self-hosted is not running
FIRECRAWL_API_KEY=

# ─── Neo4j Database ─────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Python (Sherlock + Holehe + Scrapling) ─────────────────
# Set to your Python executable. Separate env for Scrapling if needed.
PYTHON_PATH=python3
SCRAPLING_PYTHON=python3
# SHERLOCK_BIN=sherlock  # optional override if not on PATH

# ─── Obsidian Vault (optional) ──────────────────────────────
# Absolute path to your Obsidian vault. Defaults to ~/Agent_Knowladges/OSINT/OSINT-Agent
# OBSIDIAN_VAULT=/path/to/your/vault

# ─── Optional ───────────────────────────────────────────────
GITHUB_TOKEN=
HIBP_API_KEY=
SERP_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
GRAPH_PORT=3333

