# ─── Zorunlu ───────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Self-Hosted Arama & Scraping (Docker) ─────────
# docker compose up -d ile baslatilir
SEARXNG_URL=http://localhost:8888
FIRECRAWL_URL=http://localhost:3002/v1/scrape

# ─── Arama Motorları (zincir: SearXNG → Brave → Google CSE → Tavily) ─────
BRAVE_SEARCH_API_KEY=BSA...
# Google Custom Search — https://programmablesearchengine.google.com/
# GOOGLE_SEARCH_API_KEY = Google Cloud Console'dan alınan API anahtarı
# GOOGLE_SEARCH_CX     = Programmable Search Engine ID (cx parametresi)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
TAVILY_API_KEY=tvly-...
# Firecrawl Cloud fallback — sadece self-hosted calismiyorsa
FIRECRAWL_API_KEY=

# ─── Neo4j Veritabanı ───────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Python (Sherlock + Holehe + Scrapling) ─────────
PYTHON_PATH=/home/KULLANICI/anaconda3/envs/scrapling/bin/python

# ─── İsteğe Bağlı ───────────────────────────────────
GITHUB_TOKEN=
HIBP_API_KEY=
SERP_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
GRAPH_PORT=3333
